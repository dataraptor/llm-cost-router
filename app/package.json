{
  "name": "frugalroute-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "FrugalRoute web frontend — dc-runtime Design Component wired to the live API.",
  "scripts": {
    "test": "node --test \"tests/unit/**/*.test.js\"",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test tests/e2e/a11y.spec.js",
    "test:perf": "node tests/e2e/perf.mjs",
    "test:integration": "playwright test --config playwright.integration.config.js",
    "screenshot": "node tests/e2e/screenshot.mjs",
    "serve": "node tests/e2e/static-server.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.49.0"
  }
}
