# Copy to .env (gitignored) and fill in. Only needed for live API calls
# (the @api/@azure tests and the router/eval paths in later splits).
# No-key unit tests run green without any of this set.

# --- Native Anthropic backend (the engine's spec default). ---
# Enables @pytest.mark.api tests.
ANTHROPIC_API_KEY=sk-ant-...

# --- Live-demo backend: Azure OpenAI gpt-5.5 via the Anthropic-shaped adapter
#     (frugalroute.azure_client). Enables @pytest.mark.azure tests. ---
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=...
OPENAI_API_VERSION=2025-01-01-preview
CHAT_LLM_MODEL=gpt-5.5
