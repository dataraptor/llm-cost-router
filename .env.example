# FrugalRoute — environment configuration (copy to .env, which is gitignored).
#
# Every variable below has a safe default; nothing here is required to run the
# no-key tests or to serve the precomputed Frontier proof. Live routing needs a
# model backend key (Anthropic, or the Azure gpt-5.5 adapter this build ships).

# ============================================================================
# Model backend credentials (only needed for LIVE routing / eval)
# ============================================================================

# --- Native Anthropic backend (the engine's spec default). ---
# Read only from the environment; never logged or serialized (split-11 redaction).
ANTHROPIC_API_KEY=sk-ant-...

# --- Live-demo backend: Azure OpenAI gpt-5.5 via the Anthropic-shaped adapter
#     (frugalroute.azure_client). Select it with FRUGALROUTE_BACKEND=azure. ---
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=...
OPENAI_API_VERSION=2025-01-01-preview
CHAT_LLM_MODEL=gpt-5.5

# ============================================================================
# Engine operational config (core/src/frugalroute/config.py) — validated at
# startup; an invalid value fails loudly rather than degrading silently.
# ============================================================================

# Max simultaneous Anthropic calls process-wide (build-spec §17 "~6 workers").
# Also sizes the API's concurrency back-pressure. Must be >= 1.
FRUGALROUTE_MAX_CONCURRENCY=6

# Server-side per-request timeout in seconds; on exceed the API returns a typed
# 504 (never a hung connection). Must be > 0.
FRUGALROUTE_REQUEST_TIMEOUT_S=60

# Log level for the structured JSON logger (CRITICAL|ERROR|WARNING|INFO|DEBUG).
FRUGALROUTE_LOG_LEVEL=INFO

# ============================================================================
# API deployment config (api/src/frugalroute_api/config.py), prefix FRUGALROUTE_
# ============================================================================

# Live backend selector: "azure" injects the gpt-5.5 adapter; empty = native
# Anthropic client (the engine default).
FRUGALROUTE_BACKEND=

# Comma-separated CORS allow-origins. Default "*" for local dev — LOCK DOWN in
# production (split 13 serves same-origin, so CORS is not needed there at all).
FRUGALROUTE_CORS_ORIGINS=*

# Optional path to a trained predictive router (joblib) for live predictive
# routing. Absent → predictive live returns a clear 400.
# FRUGALROUTE_ROUTER_PATH=models/gsm8k.joblib

# --- Per-IP rate limit (token bucket). Off by default for local dev; enable and
#     tune in production. The Anthropic-side 429 is handled separately by SDK
#     backoff and surfaced as the split-09 `retry` event. ---
FRUGALROUTE_RATE_LIMIT_ENABLED=false
FRUGALROUTE_RATE_LIMIT_BURST=60
FRUGALROUTE_RATE_LIMIT_REFILL_PER_S=1.0
